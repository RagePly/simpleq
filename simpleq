#!/bin/bash

# Check dependencies

if ! which pdflatex pdfcrop pdftocairo 1>/dev/null 2>&1; then
  echo Error: missing dependencies: 1>&2
  if ! which pdflatex 1>/dev/null 2>&1; then
    echo pdflatex 1>&2
  fi
  if ! which pdfcrop 1>/dev/null 2>&1; then
    echo pdfcrop 1>&2
  fi
  if ! which pdftocairo 1>/dev/null 2>&1; then
    echo pdftocairo 1>&2
  fi

  exit 1
fi

mkdir -p /tmp/simpleq
OUTDIR=$(mktemp -p /tmp/simpleq/ -d eq.XXX)

cat <(echo '\documentclass[border=0pt]{standalone}

  % --- Core math ---
  \usepackage{amsmath,amssymb,amsfonts,mathtools}

  % --- Colors ---
  \usepackage{xcolor}

  % --- Units ---
  \usepackage{siunitx}

  % --- Symbol extensions ---
  \usepackage{bm}         % bold math
  \usepackage{mathrsfs}   % script fonts
  \usepackage{dsfont}     % double-stroke (ℝ, ℕ, indicator functions)
  \usepackage{stmaryrd}   % semantic brackets, maps, etc.
  \usepackage{wasysym}    % miscellaneous symbols
  \usepackage{esint}      % extended integral symbols
  \usepackage{cancel}     % cancel / strikeout
  \usepackage{braket}     % braket notation

  % --- Layout / highlighting ---
  \usepackage{empheq}     % boxed / highlighted equations

  % --- Math helpers ---
  \usepackage{commath}    % derivatives, norms, abs, etc.

  % --- Fonts ---
  \usepackage{lmodern}        % better default Latin Modern
  \usepackage{inconsolata}    % high-quality monospace

  % --- Microtypography (safe even for standalone) ---
  \usepackage{microtype}

  % --- Optional: better spacing control ---
  \usepackage{relsize}

  % --- Sensible defaults ---
  \everymath{\displaystyle}

  \begin{document}
  \begin{equation*}
  \displaystyle') \
  - \
  <(echo '\end{equation*}
  \end{document}') > $OUTDIR/eq.tex

pdflatex -interaction=nonstopmode --output-directory=$OUTDIR $OUTDIR/eq.tex 1>&2 \

if [ -f $OUTDIR/eq.pdf ]; then
  pdfcrop $OUTDIR/eq.pdf $OUTDIR/eq-crop.pdf 1>&2 \
    && pdftocairo -png  -r 1200 -transp -singlefile $OUTDIR/eq-crop.pdf -

  res=$?
  if [ $res -ne 0 ]; then
    echo No image created 1>&2
  fi

  exit $res
else
  echo No image created 1>&2
  exit 1
fi

